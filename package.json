{
  "name": "soulforge",
  "version": "1.0.0",
  "description": "AI-Powered Terminal IDE by proxySoul",
  "module": "src/index.tsx",
  "type": "module",
  "license": "AGPL-3.0-only",
  "author": "proxySoul",
  "bin": {
    "soulforge": "./src/index.tsx",
    "sf": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "latest",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.10",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.51",
    "@ai-sdk/google": "^3.0.35",
    "@ai-sdk/openai": "^3.0.38",
    "@ai-sdk/xai": "^3.0.62",
    "ai": "^6.0.106",
    "chalk": "^5.6.2",
    "ink": "^6.8.0",
    "ink-scroll-list": "^0.4.1",
    "ink-scroll-view": "^0.3.6",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.3",
    "neovim": "^5.4.0",
    "react": "^19.2.4",
    "shiki": "^4.0.1",
    "tree-sitter-wasms": "^0.1.13",
